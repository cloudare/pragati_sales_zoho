# ===== DATABASE =====
DATABASE_URL=postgresql://pragati:pragati@localhost:5432/pragati_sales

# ===== APP =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=CHANGE-ME-very-long-random-string
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ===== CORS =====
# Comma-separated allowed origins (your Vercel domain + any other frontends)
CORS_ORIGINS=https://your-frontend.vercel.app

# In production with Alembic, set to false (default true is for dev convenience only)
AUTO_CREATE_TABLES=false

# ===== AUTH =====
# Access token lifetime - keep short (15-30 min) to limit stolen-token blast radius
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== PASSWORD POLICY =====
PASSWORD_MIN_LENGTH=10

# ===== LOGIN PROTECTION =====
# Rate limit per IP for /api/auth/login and /api/auth/2fa/verify
LOGIN_RATE_LIMIT=5/minute

# Account lockout after N consecutive failed attempts
MAX_FAILED_LOGIN_ATTEMPTS=10
LOCKOUT_MINUTES=15

# ===== 2FA =====
# Comma-separated roles that REQUIRE 2FA. Empty = optional for all.
# Recommended for production: admin,accounts
REQUIRE_2FA_FOR_ROLES=admin,accounts

# ===== TALLY =====
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TALLY_API_KEY=CHANGE-ME-tally-shared-secret

# ===== ZOHO BOOKS =====
ZOHO_CLIENT_ID=1000.RWK99OIJQIYPKB8WMPLT1YCM0142LL
ZOHO_CLIENT_SECRET=cf93079323600910dc24b6c9eab80617f8767b900b
ZOHO_REFRESH_TOKEN=1000.c5b4a17161f731c69b5b56db75e0b583.00f5a3feca58b684639236a696763198
ZOHO_ORG_ID=60043759810
ZOHO_DC=in
# For local dev only: set ZOHO_DC=local-mock to use tools/mock_zoho.py

# ===== FILES =====
UPLOAD_DIR=/var/lib/pragati/uploads
MAX_UPLOAD_SIZE_MB=10
